<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="001-init-chats" author="Oleg V. Kryuchin">

    <createTable tableName="krrg_chats" remarks="Чаты">
        <column name="id" type="BIGINT" remarks="Идентификатор чата">
            <constraints primaryKey="true" nullable="false"/>
        </column>
        <column name="name" type="varchar(64)" remarks="Ник">
            <constraints nullable="true"/>
        </column>
        <column name="status" type="int" remarks="Статус"/>
    </createTable>

</databaseChangeLog>